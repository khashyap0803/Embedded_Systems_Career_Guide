<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slate_950">

    <!-- Animated Background with better transparency -->
    <ImageView
        android:id="@+id/background_animation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.2"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_tech_grid_tile" />

    <!-- Main Scrollable Content -->
    <ScrollView
        android:id="@+id/scroll_view_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <RelativeLayout
            android:id="@+id/map_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="2000dp"
            android:paddingStart="20dp"
            android:paddingTop="40dp"
            android:paddingEnd="20dp"
            android:paddingBottom="80dp">

            <!-- Enhanced Header Card with better glassmorphism -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/header_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_marginBottom="30dp"
                app:cardBackgroundColor="@color/glass_primary"
                app:cardCornerRadius="24dp"
                app:cardElevation="16dp"
                app:strokeColor="@color/indigo_400"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🎯 Embedded Systems Journey"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <!-- User Progress Stats with reset values -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <!-- Total XP - Start with 0 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_total_xp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                                android:textColor="@color/emerald_400"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total XP"
                                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="@color/slate_300" />
                        </LinearLayout>

                        <!-- Current Stage - Start with 1 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_current_level"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                                android:textColor="@color/indigo_400"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Stage"
                                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="@color/slate_300" />
                        </LinearLayout>

                        <!-- Streak - Start with 1 for today -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_streak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                                android:textColor="@color/orange_400"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔥 Streak"
                                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="@color/slate_300" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Progress Bar - Start at 0% -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_overall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:progress="0"
                        app:indicatorColor="@color/emerald_400"
                        app:trackColor="@color/slate_700"
                        app:trackCornerRadius="8dp"
                        app:trackThickness="8dp" />

                    <TextView
                        android:id="@+id/text_progress_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"
                        android:text="0% Complete • 0 of 16 stages"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="@color/slate_400" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stage Path Container - This will be populated dynamically -->
            <LinearLayout
                android:id="@+id/stages_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/header_card"
                android:orientation="vertical" />

        </RelativeLayout>
    </ScrollView>

    <!-- Removed Floating Action Button for Help as requested -->

</FrameLayout>
