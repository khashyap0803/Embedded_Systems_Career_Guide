<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="20dp">

    <!-- Connection Line (Top) -->
    <View
        android:id="@+id/connection_line_top"
        android:layout_width="4dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:background="@color/cyan_400"
        android:visibility="visible" />

    <!-- Stage Node Card -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp">

        <!-- Main Stage Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/stage_card"
            android:layout_width="280dp"
            android:layout_height="140dp"
            android:layout_centerInParent="true"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardBackgroundColor="@color/glass_primary"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:strokeColor="@color/indigo_400"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- Stage Icon Container -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical">

                    <!-- Icon Background Circle -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        app:cardBackgroundColor="@color/indigo_600"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="8dp">

                        <ImageView
                            android:id="@+id/stage_icon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_foundations"
                            android:tint="@color/white" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Lock Overlay for Locked Stages -->
                    <ImageView
                        android:id="@+id/lock_overlay"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/rounded_background"
                        android:backgroundTint="@color/slate_700"
                        android:padding="4dp"
                        android:src="@drawable/ic_lock"
                        android:tint="@color/slate_400"
                        android:visibility="gone" />
                </FrameLayout>

                <!-- Stage Content -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <!-- Stage Number -->
                    <TextView
                        android:id="@+id/stage_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_background"
                        android:backgroundTint="@color/emerald_400"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="Stage 1"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <!-- Stage Title -->
                    <TextView
                        android:id="@+id/stage_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Introduction to Embedded Systems"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <!-- Stage Subtitle -->
                    <TextView
                        android:id="@+id/stage_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Foundation &amp; Basics"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/slate_300" />

                    <!-- XP Reward -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/stage_xp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="+100 XP"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="@color/yellow_400"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Completion Stars -->
                <LinearLayout
                    android:id="@+id/stars_container"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/star_1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_star_outline"
                        android:tint="@color/yellow_400" />

                    <ImageView
                        android:id="@+id/star_2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="4dp"
                        android:src="@drawable/ic_star_outline"
                        android:tint="@color/yellow_400" />

                    <ImageView
                        android:id="@+id/star_3"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="4dp"
                        android:src="@drawable/ic_star_outline"
                        android:tint="@color/yellow_400" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Side Decorations for Active Stage -->
        <ImageView
            android:id="@+id/sparkle_left"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignTop="@id/stage_card"
            android:layout_marginStart="10dp"
            android:layout_marginTop="20dp"
            android:layout_toStartOf="@id/stage_card"
            android:src="@drawable/ic_star_filled"
            android:tint="@color/yellow_400"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/sparkle_right"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignTop="@id/stage_card"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="10dp"
            android:layout_toEndOf="@id/stage_card"
            android:src="@drawable/ic_star_filled"
            android:tint="@color/cyan_400"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Connection Line (Bottom) -->
    <View
        android:id="@+id/connection_line_bottom"
        android:layout_width="4dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:background="@color/cyan_400"
        android:visibility="visible" />
</LinearLayout>
