<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slate_900"
    android:fitsSystemWindows="true">

    <!-- Top Bar with Timer -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <!-- Challenge Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Challenge 3 - Write Complete Code"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F" />

                <TextView
                    android:id="@+id/tvRollNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Roll: 160122735108"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <!-- Question Number & Progress Dots -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvQuestionNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Question 1 of 3"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#D32F2F"
                        android:layout_marginEnd="12dp" />

                    <View
                        android:id="@+id/dot1"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/dot_active"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:id="@+id/dot2"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/dot_inactive"
                        android:layout_marginEnd="6dp" />

                    <View
                        android:id="@+id/dot3"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/dot_inactive" />

                </LinearLayout>

            </LinearLayout>

            <!-- Timer (30 min for Challenge 3) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/timerCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFCDD2"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:contentDescription="Timer" />

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30:00"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#D32F2F"
                        android:fontFamily="monospace"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Warning Indicator -->
            <ImageView
                android:id="@+id/ivWarning"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="12dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:contentDescription="Warning"
                android:visibility="gone" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Main Content ScrollView -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Scenario Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFEBEE"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvScenario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏭 INDUSTRIAL GAS MONITORING"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#D32F2F" />

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textSize="13sp"
                        android:textColor="#424242"
                        android:lineSpacingMultiplier="1.3"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Requirements Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSecondaryContainer"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 REQUIREMENTS"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSecondaryContainer" />

                    <TextView
                        android:id="@+id/tvRequirements"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Full Code Editor Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#1E1E1E"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Editor Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="// Write your COMPLETE code below"
                            android:textSize="12sp"
                            android:textColor="#4CAF50"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tvLineCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 lines"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:fontFamily="monospace" />

                    </LinearLayout>

                    <!-- Full Code Input Area -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#2D2D2D"
                        app:cardCornerRadius="8dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="#4CAF50">

                        <EditText
                            android:id="@+id/etCompleteCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="15"
                            android:maxLines="30"
                            android:textSize="12sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="monospace"
                            android:background="@android:color/transparent"
                            android:padding="12dp"
                            android:inputType="textMultiLine|textNoSuggestions"
                            android:gravity="top"
                            android:hint="#include &lt;Wire.h&gt;\n\n// Pin definitions\n\nvoid setup() {\n  \n}\n\nvoid loop() {\n  \n}"
                            android:textColorHint="#555555"
                            android:longClickable="false"
                            android:textIsSelectable="false"
                            android:importantForAutofill="no" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Hints Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3E0">

                <TextView
                    android:id="@+id/tvHints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 Hints: Use Wire.h for I2C"
                    android:textSize="12sp"
                    android:textColor="#E65100"
                    android:padding="10dp" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Bar with Navigation -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Progress Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvProgress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0/3 questions completed"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBarCompletion"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp" />

            <!-- Navigation Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Previous Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrevQuestion"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="◀ PREV"
                    android:textSize="11sp"
                    android:enabled="false"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:cornerRadius="8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Save Progress Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="💾 SAVE"
                    android:textSize="11sp"
                    style="@style/Widget.Material3.Button.TextButton"
                    app:cornerRadius="8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Next Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNextQuestion"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="NEXT ▶"
                    android:textSize="11sp"
                    style="@style/Widget.Material3.Button.TonalButton"
                    app:cornerRadius="8dp" />

                <!-- Submit Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmit"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="SUBMIT ALL"
                    android:textSize="11sp"
                    android:visibility="gone"
                    app:backgroundTint="#D32F2F"
                    app:cornerRadius="8dp"
                    app:icon="@android:drawable/ic_menu_send"
                    app:iconGravity="end" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:background="?attr/colorSurface">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp" />

            <TextView
                android:id="@+id/tvLoadingMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
