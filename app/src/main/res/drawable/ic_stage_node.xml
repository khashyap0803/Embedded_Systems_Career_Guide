<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow/shadow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#3300FFFF"/>
            <size android:width="64dp" android:height="64dp"/>
        </shape>
    </item>
    <!-- Main circle -->
    <item android:left="4dp" android:right="4dp" android:top="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="?attr/colorPrimary"/>
        </shape>
    </item>
    <!-- Inner icon placeholder (a smaller circle) -->
    <item android:left="18dp" android:right="18dp" android:top="18dp" android:bottom="18dp">
        <shape android:shape="oval">
            <solid android:color="?attr/colorOnPrimary"/>
        </shape>
    </item>
</layer-list>